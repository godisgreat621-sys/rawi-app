rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── دوال مساعدة ────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'admin';
    }

    function isActiveUser() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('isActive', true) == true;
    }

    // ── المستخدمون ──────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isUser(uid);
      allow update: if isUser(uid) || isAdmin();
      allow delete: if isAdmin();

      match /readingProgress/{novelId} {
        allow read, write: if isUser(uid);
      }

      match /pointsHistory/{docId} {
        allow read: if isUser(uid) || isAdmin();
        allow write: if false;
      }

      match /readingLists/{listName} {
        allow read, write: if isUser(uid);
      }

      match /notifications/{notifId} {
        allow read: if isUser(uid);
        allow create, update, delete: if isUser(uid);
      }

      match /followers/{followerId} {
        allow read: if true;
        allow create, delete: if isUser(uid);
      }

      match /following/{followingId} {
        allow read: if true;
        allow create, delete: if isUser(uid);
      }
    }

    // ── الروايات ────────────────────────────────────────────────────────────
    match /novels/{novelId} {
      allow read: if true;
      allow create: if isAuth() && isActiveUser()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth() && (
        (resource.data.authorId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['authorId', 'readers']))
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['readers', 'likes', 'rating', 'ratingCount', 'lastActivityAt', 'bookmarkedBy'])
        || isAdmin()
      );
      allow delete: if resource.data.authorId == request.auth.uid || isAdmin();

      match /chapters/{chapterId} {
        allow read: if true;
        allow create, update: if isAuth()
          && get(/databases/$(database)/documents/novels/$(novelId))
              .data.authorId == request.auth.uid;
        allow delete: if isAuth() && (
          get(/databases/$(database)/documents/novels/$(novelId))
              .data.authorId == request.auth.uid
          || isAdmin()
        );

        match /comments/{commentId} {
          allow read: if true;
          allow create: if isAuth() && isActiveUser()
            && request.resource.data.userId == request.auth.uid;
          allow update, delete: if isUser(resource.data.userId) || isAdmin();

          match /replies/{replyId} {
            allow read: if true;
            allow create: if isAuth() && isActiveUser()
              && request.resource.data.userId == request.auth.uid;
            allow update, delete: if isUser(resource.data.userId) || isAdmin();
          }
        }
      }

      match /followers/{uid} {
        allow read: if true;
        allow write: if isUser(uid);
      }

      match /presences/{uid} {
        allow read: if true;
        allow write: if isUser(uid);
      }
    }

    // ── الإشعارات (مستوى أعلى) ──────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── المسودات ────────────────────────────────────────────────────────────
    match /drafts/{draftId} {
      allow create: if isAuth()
        && request.resource.data.authorId == request.auth.uid;
      allow read, update, delete: if isAuth()
        && resource.data.authorId == request.auth.uid;
    }

    // ── إعدادات النظام ──────────────────────────────────────────────────────
    match /system_settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── طلبات الدعم ─────────────────────────────────────────────────────────
    match /support_requests/{reqId} {
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isUser(resource.data.userId) || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
