rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /novels/{novelId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);

      match /chapters/{chapterId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid &&
          get(/databases/$(database)/documents/novels/$(novelId)).data.authorId == request.auth.uid;
        allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
        allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }

    match /drafts/{draftId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == resource.data.authorId;
    }

    match /support_requests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow read: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /followers/{followerId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /following/{followingId} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
